{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "baseUrl": ".",
    "paths": {
      "@abroad-matrimony/shared": ["libs/shared/src/index.ts"],
      "@abroad-matrimony/config": ["libs/config/src/index.ts"],
      "@abroad-matrimony/logger": ["libs/logger/src/index.ts"],
      "@abroad-matrimony/db": ["libs/db/src/index.ts"],
      "@abroad-matrimony/cache": ["libs/cache/src/index.ts"],
      "@abroad-matrimony/event-bus": ["libs/event-bus/src/index.ts"],
      "@abroad-matrimony/queue": ["libs/queue/src/index.ts"],
      "@abroad-matrimony/auth": ["libs/auth/src/index.ts"],
      "@abroad-matrimony/profile": ["libs/profile/src/index.ts"],
      "@abroad-matrimony/matching": ["libs/matching/src/index.ts"],
      "@abroad-matrimony/notification": ["libs/notification/src/index.ts"],
      "@abroad-matrimony/payment": ["libs/payment/src/index.ts"],
      "@abroad-matrimony/storage": ["libs/storage/src/index.ts"],
      "@abroad-matrimony/connections": ["libs/connections/src/index.ts"],
      "@abroad-matrimony/groups": ["libs/groups/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist"]
}
