# ─────────────────────────────────────────────
# Seeder App — Environment Variables
# Copy to .env and fill in values
# NEVER run this app in production (hard env guard in server.ts)
# ─────────────────────────────────────────────

NODE_ENV=development
SEEDER_PORT=3100

# ── Gateway connection ──────────────────────────────────
# URL of the running gateway (apps/gateway) that the seeder calls
GATEWAY_URL=http://localhost:3000

# Shared secret — must match SEEDER_SECRET in apps/gateway .env
SEEDER_SECRET=change-me-random-secret-min-32-chars

# ── Database (same Supabase as gateway) ────────────────
DATABASE_URL=postgresql://postgres.xxx:password@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxx:password@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# ── Redis (same instance as gateway) ──────────────────
REDIS_URL=redis://localhost:6379

# ── S3 (for photo assignment) ──────────────────────────
# Prefix where operator has uploaded male/female profile photos
# e.g. seeder/profile-photos/male/001.jpg, seeder/profile-photos/female/001.jpg
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
SEEDER_PHOTO_S3_PREFIX=seeder/profile-photos

# ── Seeder configuration ───────────────────────────────
# Total profiles to create on first full run
SEEDER_INITIAL_COUNT=500
# Drip: new profiles per cycle (picked randomly between min and max)
SEEDER_DRIP_MIN=3
SEEDER_DRIP_MAX=5
# Drip cycle interval in hours
SEEDER_DRIP_INTERVAL_HOURS=3
