{
  "name": "@abroad-matrimony/source",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "test:unit": "jest --projects libs/auth libs/matching libs/messaging libs/notification libs/payment libs/connections libs/groups libs/gatherings libs/verification libs/habits libs/introductions libs/prompts libs/saved-profiles libs/trust libs/profile libs/ai apps/gateway apps/seeder --no-coverage",
    "test:coverage": "jest --projects libs/auth libs/matching libs/messaging libs/notification libs/payment libs/connections libs/groups libs/gatherings libs/verification libs/habits libs/introductions libs/prompts libs/saved-profiles libs/trust libs/profile libs/ai apps/gateway apps/seeder --coverage",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\" --ignore-path .prettierignore",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "db:generate": "prisma generate --schema=libs/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=libs/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema=libs/db/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=libs/db/prisma/schema.prisma",
    "db:seed": "ts-node -r tsconfig-paths/register libs/db/src/seed.ts"
  },
  "devDependencies": {
    "@nx/eslint": "^22.7.4",
    "@nx/express": "^22.7.4",
    "@nx/jest": "^22.7.4",
    "@nx/js": "22.7.2",
    "@nx/node": "^22.7.4",
    "@nx/react": "^22.7.4",
    "@nx/vite": "^22.7.4",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-security": "^3.0.0",
    "jest": "^29.7.0",
    "nx": "22.7.2",
    "prettier": "^3.8.1",
    "prisma": "^6.1.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.3.0",
    "typescript": "~5.5.4"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@aws-sdk/s3-request-presigner": "^3.1055.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@prisma/client": "^6.1.0",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.4.0",
    "cloudevents": "^1.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "openai": "^6.39.1",
    "razorpay": "^2.9.2",
    "speakeasy": "^2.0.0",
    "stripe": "^16.0.0",
    "twilio": "^6.0.2",
    "uuid": "^14.0.0",
    "winston": "^3.17.0",
    "zod": "^3.22.0"
  }
}
