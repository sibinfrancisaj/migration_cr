# ─────────────────────────────────────────────────────────────────────────────
# Production environment variables — Abroad Matrimony
#
# Copy to .env.production and fill in real values.
# NEVER commit .env.production to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Transaction pooler — used by Prisma at runtime (port 6543 + pgbouncer=true)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Session pooler — used by Prisma Migrate / db push (port 5432, no pgbouncer)
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
# Strong random password (min 32 chars). Injected into redis.prod.conf at startup.
REDIS_PASSWORD=change-me-strong-random-password-32-chars-min

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-different-from-access-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Admin ─────────────────────────────────────────────────────────────────────
# Base32 TOTP secret for admin 2FA (generate with: node -e "require('crypto').randomBytes(20).toString('base64')")
ADMIN_TOTP_SECRET=change-me-base32-totp-secret

# ── Twilio (OTP + SMS) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ── Brevo (Email) ─────────────────────────────────────────────────────────────
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_FROM_EMAIL=noreply@abroadmatrimony.com

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key from your Firebase service account JSON (keep \n as literal \n)
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# ── AWS S3 + CloudFront ───────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=abroad-matrimony-media
# CloudFront distribution domain (no trailing slash)
AWS_CLOUDFRONT_DOMAIN=https://dxxxxxxxxxxxx.cloudfront.net

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=<your-stripe-live-secret-key>
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Price ID for the Founding Member subscription tier
STRIPE_FOUNDING_MEMBER_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Razorpay (India payments) ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Payment redirect URLs ─────────────────────────────────────────────────────
PAYMENT_SUCCESS_URL=https://abroadmatrimony.com/payment/success
PAYMENT_CANCEL_URL=https://abroadmatrimony.com/payment/cancel

# ── OpenAI (optional — AI features disabled when absent) ─────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Seeder / Bot simulator ────────────────────────────────────────────────────
# Strong random secret (min 32 chars). Same value used in gateway + seeder.
SEEDER_SECRET=change-me-seeder-secret-min-32-chars
SEEDER_PHOTO_S3_PREFIX=seeder/profile-photos
SEEDER_INITIAL_COUNT=500

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx

# ── Trusted device settings ────────────────────────────────────────────────────
TRUSTED_DEVICE_TTL_DAYS=90

# ── Let's Encrypt (used by certbot profile in docker-compose.prod.yml) ────────
CERTBOT_EMAIL=admin@abroadmatrimony.com
