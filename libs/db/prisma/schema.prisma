generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ─── Auth & Identity ─────────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  phone           String    @unique
  email           String?   @unique
  role            UserRole  @default(USER)
  isPhoneVerified Boolean   @default(false)
  isEmailVerified Boolean   @default(false)
  isSeeded        Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  profile              Profile?
  devices              Device[]
  refreshTokens        RefreshToken[]
  realLifeAnswers      RealLifeAnswer[]
  storyPromptAnswers   StoryPromptAnswer[]
  media                Media[]
  groupMemberships     GroupMember[]
  connectionsSent      Connection[]          @relation("ConnectionSender")
  connectionsReceived  Connection[]          @relation("ConnectionReceiver")
  matchesAsA           Match[]               @relation("MatchUserA")
  matchesAsB           Match[]               @relation("MatchUserB")
  checkIns             CheckIn[]
  verificationRequests VerificationRequest[]
  memberships          Membership[]
  diamondLedger        DiamondLedger[]
  paymentIntents       PaymentIntent[]
  notifications        Notification[]
  flagsReported        Flag[]                @relation("FlagReporter")
  flagsReceived        Flag[]                @relation("FlagTarget")
  eventRsvps           EventRsvp[]
  messagesSent         Message[]
  savedProfiles        SavedProfile[]        @relation("SavedByUser")
  savedByUsers         SavedProfile[]        @relation("SavedUser")
  blocksGiven          UserBlock[]           @relation("BlockSender")
  blocksReceived       UserBlock[]           @relation("BlockReceived")
  habitLogs            HabitLog[]
  promptResponses      PromptResponse[]
  promptResonates      PromptResonate[]
  introductionsAsA     Introduction[]        @relation("IntroUserA")
  introductionsAsB     Introduction[]        @relation("IntroUserB")
  matchTuning          MatchTuning?
  emailMagicLinks      EmailMagicLink[]
  profileEmbedding     ProfileEmbedding?
  groupPosts           GroupPost[]
  groupPostComments    GroupPostComment[]
  groupPostLikes       GroupPostLike[]
  groupProposals       GroupProposal[]

  @@index([phone])
  @@index([email])
  @@index([role])
  @@index([isSeeded])
  @@index([createdAt])
  @@map("users")
}

model Device {
  id               String    @id @default(uuid())
  userId           String
  fingerprint      String
  name             String?
  platform         String?
  pushToken        String?
  isTrusted        Boolean   @default(false)
  /// Timestamp when isTrusted was last set to true (i.e. last successful OTP on this device).
  trustedAt        DateTime?
  /// Trust expiry — bypass is only valid before this timestamp. Null = not trusted.
  trustedExpiresAt DateTime?
  lastSeenAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([userId])
  @@index([trustedExpiresAt])
  @@map("devices")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  deviceId  String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model AdminUser {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          AdminRole @default(MODERATOR)
  isTotpEnabled Boolean   @default(false)
  totpSecret    String?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  auditLogs            AuditLog[]
  verificationReviews  VerificationRequest[] @relation("VerificationReviewer")
  flagReviews          Flag[]                @relation("FlagModerator")
  groupProposalReviews GroupProposal[]       @relation("GroupProposalReviewer")
  introDropApprovals   IntroductionDrop[]    @relation("IntroDropApprover")

  @@index([email])
  @@map("admin_users")
}

// ─── Profile & Content ───────────────────────────────────────────────────────

model Profile {
  id                   String             @id @default(uuid())
  userId               String             @unique
  name                 String
  dateOfBirth          DateTime
  gender               Gender
  currentCity          String
  currentCountry       String
  settlementIntent     String
  bio                  String?
  completionScore      Int                @default(0)
  verificationStatus   VerificationStatus @default(PENDING)
  isPaused             Boolean            @default(false)
  trustScore           Int                @default(0)
  isSeeded             Boolean            @default(false)
  voiceIntroTranscript String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([currentCountry])
  @@index([verificationStatus])
  @@index([isPaused])
  @@index([isSeeded])
  @@map("profiles")
}

model RealLifeAnswer {
  id          String              @id @default(uuid())
  userId      String
  questionKey RealLifeQuestionKey
  value       Json
  updatedAt   DateTime            @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionKey])
  @@index([userId])
  @@map("real_life_answers")
}

model StoryPromptAnswer {
  id        String         @id @default(uuid())
  userId    String
  promptKey StoryPromptKey
  answer    String
  updatedAt DateTime       @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, promptKey])
  @@index([userId])
  @@map("story_prompt_answers")
}

model Media {
  id         String    @id @default(uuid())
  userId     String
  type       MediaType
  s3Key      String    @unique
  url        String
  order      Int?
  isVerified Boolean   @default(false)
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("media")
}

// ─── Saved Profiles & Blocking ───────────────────────────────────────────────

model SavedProfile {
  id          String            @id @default(uuid())
  userId      String
  savedUserId String
  label       SavedProfileLabel @default(INTERESTED)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User              @relation("SavedByUser", fields: [userId], references: [id], onDelete: Cascade)
  savedUser   User              @relation("SavedUser", fields: [savedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, savedUserId])
  @@index([userId])
  @@index([savedUserId])
  @@map("saved_profiles")
}

model UserBlock {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  reason    String?
  createdAt DateTime @default(now())

  blocker   User     @relation("BlockSender", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlockReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("user_blocks")
}

// ─── Groups ───────────────────────────────────────────────────────────────────

model Group {
  id             String          @id @default(uuid())
  name           String
  type           GroupType       @default(REGIONAL)
  scope          GroupScope      @default(COUNTRY)
  region         String
  country        String?
  city           String?
  parentGroupId  String?
  description    String?
  coverImageUrl  String?
  professionTag  String?
  culturalTag    String?
  status         GroupStatus     @default(FORMING)
  accessType     GroupAccessType @default(OPEN)
  isActive       Boolean         @default(true)
  isSeeded       Boolean         @default(false)
  memberCount    Int             @default(0)
  launchDate     DateTime
  introDayOfWeek Int             @default(0)
  capacity       Int             @default(20)
  maxMembers     Int             @default(20)
  creditCost     Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  parentGroup   Group?        @relation("GroupHierarchy", fields: [parentGroupId], references: [id])
  childGroups   Group[]       @relation("GroupHierarchy")
  members       GroupMember[]
  events        Event[]
  introDrops    IntroDropLog[]
  introductions Introduction[]
  posts         GroupPost[]

  @@index([status])
  @@index([type])
  @@index([scope])
  @@index([region])
  @@index([country])
  @@index([parentGroupId])
  @@index([isActive])
  @@index([isSeeded])
  @@map("groups")
}

model GroupMember {
  id        String    @id @default(uuid())
  userId    String
  groupId   String
  role      String    @default("MEMBER")
  status    String    @default("ACTIVE")
  joinedVia JoinedVia @default(MANUAL)
  joinedAt  DateTime  @default(now())
  expiresAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

model IntroDropLog {
  id        String   @id @default(uuid())
  groupId   String
  weekKey   String
  droppedAt DateTime @default(now())
  pairCount Int      @default(0)

  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, weekKey])
  @@map("intro_drop_logs")
}

// ─── Group Social Feed ────────────────────────────────────────────────────────

model GroupPost {
  id            String             @id @default(uuid())
  groupId       String
  authorId      String
  text          String?
  imageUrl      String?
  linkUrl       String?
  linkTitle     String?
  linkPreview   String?
  isPinned      Boolean            @default(false)
  likesCount    Int                @default(0)
  commentsCount Int                @default(0)
  isSeeded      Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  group         Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author        User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments      GroupPostComment[]
  likes         GroupPostLike[]

  @@index([groupId])
  @@index([authorId])
  @@index([createdAt])
  @@index([isSeeded])
  @@map("group_posts")
}

model GroupPostComment {
  id        String    @id @default(uuid())
  postId    String
  authorId  String
  text      String
  createdAt DateTime  @default(now())

  post      GroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
  @@map("group_post_comments")
}

model GroupPostLike {
  postId    String
  userId    String
  createdAt DateTime  @default(now())

  post      GroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([postId])
  @@map("group_post_likes")
}

// ─── Group Proposals ─────────────────────────────────────────────────────────

model GroupProposal {
  id                String              @id @default(uuid())
  proposedByUserId  String
  name              String
  description       String
  type              GroupType
  country           String?
  rationale         String
  status            GroupProposalStatus @default(PENDING)
  reviewedByAdminId String?
  reviewedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  proposedBy        User                @relation(fields: [proposedByUserId], references: [id], onDelete: Cascade)
  reviewedBy        AdminUser?          @relation("GroupProposalReviewer", fields: [reviewedByAdminId], references: [id])

  @@index([proposedByUserId])
  @@index([status])
  @@map("group_proposals")
}

// ─── Introduction Drops ───────────────────────────────────────────────────────

model IntroductionDrop {
  id                String                 @id @default(uuid())
  name              String
  criteria          Json
  memberPool        String[]               @default([])
  releaseAt         DateTime?
  expiresAt         DateTime?
  status            IntroductionDropStatus @default(DRAFT)
  proposedByAI      Boolean                @default(false)
  approvedByAdminId String?
  approvedAt        DateTime?
  weekKey           String?
  earlyAccessCost   Int                    @default(10)
  unlockCost        Int                    @default(25)
  isSeeded          Boolean                @default(false)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  approvedBy        AdminUser?             @relation("IntroDropApprover", fields: [approvedByAdminId], references: [id])
  introductions     Introduction[]

  @@index([status])
  @@index([releaseAt])
  @@index([isSeeded])
  @@map("introduction_drops")
}

// ─── Introductions ────────────────────────────────────────────────────────────

model Introduction {
  id              String             @id @default(uuid())
  groupId         String?
  weekKey         String?
  dropId          String?
  userAId         String
  userBId         String
  status          IntroductionStatus @default(PENDING)
  expiresAt       DateTime
  acceptedByA     Boolean            @default(false)
  acceptedByB     Boolean            @default(false)
  viewedEarlyAt   DateTime?
  unlockedEarlyAt DateTime?
  message         String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  group           Group?             @relation(fields: [groupId], references: [id], onDelete: SetNull)
  userA           User               @relation("IntroUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB           User               @relation("IntroUserB", fields: [userBId], references: [id], onDelete: Cascade)
  drop            IntroductionDrop?  @relation(fields: [dropId], references: [id], onDelete: SetNull)

  @@index([userAId])
  @@index([userBId])
  @@index([weekKey])
  @@index([dropId])
  @@index([status])
  @@map("introductions")
}

// ─── AI Profile Intelligence ──────────────────────────────────────────────────

model ProfileEmbedding {
  userId                   String   @id
  summary                  String?
  traitTags                String[] @default([])
  vibeScores               Json?
  compatibilityNotes       String?
  embedding                Unsupported("vector(1536)")?
  recommendedContactWindow Json?
  updatedAt                DateTime @updatedAt

  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profile_embeddings")
}

// ─── Matching ────────────────────────────────────────────────────────────────

model MatchScore {
  id         String   @id @default(uuid())
  userAId    String
  userBId    String
  totalScore Float
  breakdown  Json
  algorithmV String   @default("v1")
  computedAt DateTime @default(now())

  @@unique([userAId, userBId, algorithmV])
  @@index([userAId])
  @@index([userBId])
  @@index([totalScore])
  @@map("match_scores")
}

model MatchTuning {
  id        String   @id @default(uuid())
  userId    String   @unique
  weights   Json
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("match_tuning")
}

model Connection {
  id         String           @id @default(uuid())
  senderId   String
  receiverId String
  status     ConnectionStatus @default(PENDING)
  message    String?
  expiresAt  DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  sender     User             @relation("ConnectionSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User             @relation("ConnectionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  match      Match?

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@map("connections")
}

model Match {
  id           String        @id @default(uuid())
  userAId      String
  userBId      String
  connectionId String        @unique
  matchedAt    DateTime      @default(now())

  userA        User          @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB        User          @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  connection   Connection    @relation(fields: [connectionId], references: [id])
  conversation Conversation?

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@map("matches")
}

// ─── Messaging ────────────────────────────────────────────────────────────────

model Conversation {
  id            String    @id @default(uuid())
  matchId       String    @unique
  lastMessageAt DateTime?
  isArchived    Boolean   @default(false)
  createdAt     DateTime  @default(now())

  match         Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@map("conversations")
}

model Message {
  id              String       @id @default(uuid())
  conversationId  String
  senderId        String
  type            MessageType  @default(TEXT)
  content         String       @default("")
  mediaUrl        String?
  durationSeconds Int?
  flagCount       Int          @default(0)
  isHidden        Boolean      @default(false)
  readAt          DateTime?
  createdAt       DateTime     @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

// ─── Engagement ───────────────────────────────────────────────────────────────

model CheckIn {
  id          String   @id @default(uuid())
  userId      String
  weekKey     String
  answers     Json
  mood        Int?
  notes       String?
  submittedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekKey])
  @@index([userId])
  @@index([weekKey])
  @@map("check_ins")
}

// ─── Habits ──────────────────────────────────────────────────────────────────

model HabitLog {
  id         String   @id @default(uuid())
  userId     String
  habitKey   HabitKey
  logDate    DateTime @db.Date
  completed  Boolean  @default(true)
  notes      String?
  reflection String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, habitKey, logDate])
  @@index([userId])
  @@index([habitKey])
  @@index([logDate])
  @@map("habit_logs")
}

// ─── Weekly Prompts ──────────────────────────────────────────────────────────

model WeeklyPrompt {
  id          String           @id @default(uuid())
  weekKey     String           @unique
  question    String
  theme       String?
  publishedAt DateTime
  expiresAt   DateTime
  createdAt   DateTime         @default(now())

  responses   PromptResponse[]

  @@index([weekKey])
  @@index([publishedAt])
  @@map("weekly_prompts")
}

model PromptResponse {
  id            String             @id @default(uuid())
  userId        String
  promptId      String
  text          String
  type          PromptResponseType @default(TEXT)
  mediaUrl      String?
  resonateCount Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt        WeeklyPrompt       @relation(fields: [promptId], references: [id], onDelete: Cascade)
  resonates     PromptResonate[]

  @@unique([userId, promptId])
  @@index([userId])
  @@index([promptId])
  @@index([createdAt])
  @@map("prompt_responses")
}

model PromptResonate {
  id         String         @id @default(uuid())
  userId     String
  responseId String
  createdAt  DateTime       @default(now())

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  response   PromptResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@unique([userId, responseId])
  @@index([userId])
  @@index([responseId])
  @@map("prompt_resonates")
}

// ─── Events / Gatherings ──────────────────────────────────────────────────────

model Event {
  id           String      @id @default(uuid())
  groupId      String?
  title        String
  description  String?
  status       EventStatus @default(UPCOMING)
  tag          EventTag?
  creditCost   Int         @default(0)
  onlineUrl    String?
  isStandalone Boolean     @default(false)
  startAt      DateTime
  endAt        DateTime?
  location     String?
  capacity     Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  group        Group?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  rsvps        EventRsvp[]

  @@index([groupId])
  @@index([startAt])
  @@index([status])
  @@index([tag])
  @@map("events")
}

model EventRsvp {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  status    String   @default("GOING")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@map("event_rsvps")
}

// ─── Verification ────────────────────────────────────────────────────────────

model VerificationRequest {
  id          String             @id @default(uuid())
  userId      String
  idDocType   String
  idDocS3Key  String
  selfieS3Key String
  status      VerificationStatus @default(PENDING)
  reviewerId  String?
  reviewNote  String?
  submittedAt DateTime           @default(now())
  reviewedAt  DateTime?

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer    AdminUser?         @relation("VerificationReviewer", fields: [reviewerId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
  @@map("verification_requests")
}

// ─── Payments ────────────────────────────────────────────────────────────────

model Membership {
  id                 String           @id @default(uuid())
  userId             String
  plan               MembershipPlan
  provider           PaymentProvider
  providerSubId      String?          @unique
  status             MembershipStatus @default(ACTIVE)
  currentPeriodStart DateTime?
  expiresAt          DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("memberships")
}

model PaymentIntent {
  id                String          @id @default(uuid())
  userId            String
  provider          PaymentProvider
  providerPaymentId String          @unique
  amountPaise       Int
  currency          String          @default("INR")
  status            PaymentStatus   @default(PENDING)
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("payment_intents")
}

model DiamondLedger {
  id           String        @id @default(uuid())
  userId       String
  delta        Int
  reason       DiamondReason
  balanceAfter Int
  metadata     Json?
  createdAt    DateTime      @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("diamond_ledger")
}

// ─── Auth — Email Magic Links ─────────────────────────────────────────────────

model EmailMagicLink {
  id        String    @id @default(uuid())
  userId    String
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("email_magic_links")
}

// ─── Platform ────────────────────────────────────────────────────────────────

model FeatureFlag {
  id                  String   @id @default(uuid())
  key                 String   @unique
  description         String
  enabled             Boolean  @default(false)
  rolloutPercentage   Int      @default(0)
  allowedUserIds      String[] @default([])
  allowedEnvironments String[] @default([])
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([key])
  @@map("feature_flags")
}

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}

model Notification {
  id          String              @id @default(uuid())
  userId      String
  channel     NotificationChannel
  title       String
  body        String
  status      NotificationStatus  @default(PENDING)
  metadata    Json?
  sentAt      DateTime?
  deliveredAt DateTime?
  createdAt   DateTime            @default(now())

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

model Flag {
  id               String      @id @default(uuid())
  reporterId       String
  targetUserId     String
  targetEntityType String
  targetEntityId   String?
  firestoreMsgId   String?
  reason           FlagReason
  description      String?
  status           FlagStatus  @default(OPEN)
  actionTaken      FlagAction?
  moderatorId      String?
  resolution       String?
  resolvedAt       DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  reporter         User        @relation("FlagReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUser       User        @relation("FlagTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  moderator        AdminUser?  @relation("FlagModerator", fields: [moderatorId], references: [id])

  @@index([reporterId])
  @@index([targetUserId])
  @@index([status])
  @@index([targetEntityType, targetEntityId])
  @@map("flags")
}

model AuditLog {
  id          String    @id @default(uuid())
  adminUserId String
  action      String
  entity      String
  entityId    String
  before      Json?
  after       Json?
  ipAddress   String
  userAgent   String?
  createdAt   DateTime  @default(now())

  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model EventLog {
  id           String    @id @default(uuid())
  cloudEventId String    @unique
  source       String
  type         String
  subject      String?
  payload      Json
  status       String    @default("PENDING")
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("event_logs")
}

