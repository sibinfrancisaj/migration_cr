# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ADMIN_PORT=3001
API_VERSION=v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────
# Database
# Supabase: get from https://supabase.com/dashboard/project/<id>/settings/database
# Local Docker: postgresql://abroad_matrimony:local_dev_password@localhost:5432/abroad_matrimony_dev
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─────────────────────────────────────────────
# Redis (Docker local dev: redis://localhost:6379)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=am:

# ─────────────────────────────────────────────
# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_64_char_hex_secret
JWT_REFRESH_SECRET=replace_with_different_64_char_hex_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
ADMIN_JWT_SECRET=replace_with_another_64_char_hex_secret
ADMIN_JWT_EXPIRES_IN=8h

# ─────────────────────────────────────────────
# Twilio — OTP (phone verification)
# https://console.twilio.com
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# Brevo (email) — free 300/day
# https://app.brevo.com/settings/keys/api
# ─────────────────────────────────────────────
BREVO_API_KEY=xkeysib-xxxxxxxx
BREVO_FROM_EMAIL=noreply@abroadmatrimony.com
BREVO_FROM_NAME=Abroad Matrimony

# ─────────────────────────────────────────────
# Firebase — push notifications (free)
# https://console.firebase.google.com/project/<id>/settings/serviceaccounts/adminsdk
# ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=abroad-matrimony
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@abroad-matrimony.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

# ─────────────────────────────────────────────
# AWS — S3 media storage
# ─────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_S3_BUCKET=abroad-matrimony-media-dev
AWS_CLOUDFRONT_DOMAIN=

# ─────────────────────────────────────────────
# Stripe — international payments
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_FOUNDING_MEMBER_PRICE_ID=price_xxxxxxxx

# ─────────────────────────────────────────────
# Razorpay — India payments
# ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# Sentry — error tracking (free 5k errors/mo)
# ─────────────────────────────────────────────
SENTRY_DSN=

# ─────────────────────────────────────────────
# OpenTelemetry — tracing export (optional in dev)
# ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=abroad-matrimony-gateway

# ─────────────────────────────────────────────
# Feature flags
# ─────────────────────────────────────────────
FEATURE_FLAGS_CACHE_TTL_SECONDS=300

# ─────────────────────────────────────────────
# Rate limiting
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
OTP_RATE_LIMIT_MAX=3
OTP_RATE_LIMIT_WINDOW_MS=3600000
